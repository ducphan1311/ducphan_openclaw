# LLM Providers (Required)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Telegram Bot Integration (Primary Interface)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# Microsoft Teams / Graph API (Communication Agent)
TEAMS_TENANT_ID=your_tenant_id
TEAMS_CLIENT_ID=your_client_id
TEAMS_CLIENT_SECRET=your_client_secret

# Jira Integration (Task Manager Agent)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your_email@domain.com
JIRA_API_TOKEN=your_jira_api_token

# Azure Credentials (DevOps Agent)
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# System Configuration
# Time window autonomy - only active during these hours
AUTONOMY_START_HOUR=08:00
AUTONOMY_END_HOUR=18:00
TIMEZONE=Asia/Ho_Chi_Minh

# Human In The Loop (HITL) Policy
# 1 = Require approval for all actions
# 0 = Fully autonomous (except restricted commands)
HITL_FILE_DELETION=1
HITL_SYSTEM_COMMANDS=1
HITL_EXTERNAL_API=1

# OpenClaw Settings
OPENCLAW_HEARTBEAT_INTERVAL=30 # in minutes
OPENCLAW_LOCAL_ONLY=true
